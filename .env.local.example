# Supabase (get from Supabase dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# DigitalOcean Gradient AI Platform (get from DO dashboard -> Gradient AI Platform -> Serverless Inference -> Model Access Keys)
DO_GRADIENT_API_KEY=your-do-gradient-api-key
DO_GRADIENT_CHAT_MODEL=llama3.3-70b-instruct

# HuggingFace (get from huggingface.co -> Settings -> Access Tokens)
HUGGINGFACE_API_KEY=hf_your-huggingface-token
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
